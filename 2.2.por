programa {
  funcao inicio() {

real  temperatura
inteiro umidade 

 escreva(" qual é a temperatura de hoje   "  )
 leia ( temperatura)

escreva (" qual é a umidade de hoje  ")
leia (umidade )

se (temperatura >=35){
escreva (" alerta de calor ")}

se (temperatura>=18 e  temperatura<=28 e umidade>=40){
escreva (" temperatura ideal")}

se (temperatura <=5){
escreva("risco de geada ")}

se (umidade <=30){
escreva(" ar muito seco")}












  }
}
