programa {
  funcao inicio() {

inteiro a
inteiro b
inteiro va
inteiro vb

escreva(" de um valor a copo A  ")
leia(a)

escreva("agora de um valor ao copo B  ")
leia(b)
  

 escreva("o valor do copo A é  ")
escreva(a)
 
 escreva(" e o do B é  ")
escreva(b)



// contas 

va = a
vb = b
a - a
b - b
a = vb
b = va

escreva(" fazendo conversao  ")

escreva(" o novo valor do copo A é"  )
escreva (a)

escreva(" o novo valor do copo B é  ")
escreva(b)














  }
}
