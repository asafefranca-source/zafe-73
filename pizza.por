programa {
  funcao inicio() {
  inteiro pizza  
  inteiro  amigos
  inteiro quantidade 
  inteiro resto 
  
  escreva ("quantas pessoas vao comer")
  leia (amigos)
escreva( "a pizza tem quantas fatias? ")
  leia(pizza)
  
  quantidade =pizza/amigos
  resto=pizza% amigos 
  
  escreva("cada um vai comer")
  escreva(quantidade)
  escreva("pedaços")
  escreva("e vao sobrar")
  escreva("resto")
  escreva("pedaços")
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  }


