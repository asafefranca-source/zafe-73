programa {
  funcao inicio() {

inteiro altura
inteiro largura
inteiro metros 
inteiro azulejos

escreva(" sera quantos metros tem essa parede? ")
leia (altura)

escreva(" e sera quantos metros de lagura tem essa parede  ")
leia (largura)


metros= altura * largura 
azulejos = metros * 12

escreva("voce vai precisar de ")
escreva(azulejos)
escreva("para deixar a parede bonita")







  }
}
